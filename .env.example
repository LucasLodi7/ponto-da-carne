# Copie este arquivo para ".env" e preencha os valores antes de rodar o servidor.

# Chave secreta usada para assinar as sessões de login do admin.
# Gere uma única e aleatória com o comando abaixo e cole o resultado aqui:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Senha inicial do painel admin (só é usada na primeira vez que o banco de dados é criado).
# Depois disso, troque a senha pelo próprio painel — ela passa a ficar guardada
# com hash (criptografada) no banco, não em texto puro.
INITIAL_ADMIN_PASSWORD=troque-esta-senha

# Porta em que o servidor vai rodar (a maioria dos serviços de hospedagem define isso automaticamente).
PORT=3000

# Deixe como "production" quando estiver no ar de verdade (ativa cookies só via HTTPS).
NODE_ENV=production

# Só preencha isso quando for publicar num serviço com disco persistente (ex: Railway).
# Deve apontar para dentro da pasta do disco persistente (Volume), por exemplo:
#   DB_PATH=/data/data.sqlite
# Em testes locais, deixe em branco — o banco fica na própria pasta do projeto.
DB_PATH=
